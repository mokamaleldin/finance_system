generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MovementType {
  RECEIVED
  PAID
  FEE
  ADJUSTMENT
}

enum Currency {
  EGP
  USD
  TRY
  EUR
}

enum TransactionStatus {
  OPEN
  PARTIALLY_SETTLED
  SETTLED
}

enum TransferType {
  TRANSFER
  EGYPT_TO_TURKEY
  TURKEY_TO_EGYPT
  DIRECT_EXCHANGE
}

enum TransferStepStatus {
  RECEIVED
  NOT_RECEIVED
  DELIVERED
  NOT_DELIVERED
}

enum ReceivedTransferStatus {
  RECEIVED
  NOT_RECEIVED
}

enum DeliveredTransferStatus {
  DELIVERED
  NOT_DELIVERED
}

enum TransferStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum TransferExecutionType {
  RECEIVED
  DELIVERED
}

enum CapitalMovementType {
  INFLOW
  OUTFLOW
}

enum ExpenseCategory {
  RENT
  HOSPITALITY
  TRANSPORTATION
  INTERNET
  OPERATIONS
  OTHER
}

enum CommissionType {
  FIXED
  PERCENTAGE
}

enum CommissionBase {
  RECEIVED_AMOUNT
  PROFIT
}

enum CustomerKind {
  CUSTOMER
  TRADER
}

enum UserRole {
  FULL_ADMIN
  OPERATOR
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password")
  role         UserRole @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model Customer {
  id                   String                @id @default(cuid())
  name                 String
  kind                 CustomerKind          @default(CUSTOMER)
  phone                String?
  country              String?
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  movements            FinancialMovement[]
  transactionGroups    TransactionGroup[]
  transferTransactions TransferTransaction[]

  @@index([name])
  @@index([phone])
}

model TransferTransaction {
  id                      String                  @id @default(cuid())
  date                    DateTime                @default(now())
  customerId              String?
  customer                Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerNameSnapshot    String
  customerPhoneSnapshot   String?
  type                    TransferType
  receiveLocation         String?
  deliverLocation         String?
  receivedCurrency        Currency
  receivedAmount          Decimal                 @db.Decimal(18, 4)
  deliveredCurrency       Currency
  deliveredAmount         Decimal                 @db.Decimal(18, 4)
  usdRates                Json?
  usdToEgp                Decimal?                @db.Decimal(18, 8)
  usdToTry                Decimal?                @db.Decimal(18, 8)
  rateBaseCurrency        Currency?
  rateQuoteCurrency       Currency?
  costRate                Decimal                 @default(1) @db.Decimal(18, 8)
  theoreticalRate         Decimal                 @db.Decimal(18, 8)
  customerRate            Decimal                 @db.Decimal(18, 8)
  rateDifference          Decimal                 @default(0) @db.Decimal(18, 8)
  profitCurrency          Currency
  profitAmount            Decimal                 @db.Decimal(18, 4)
  receivedStatus          ReceivedTransferStatus  @default(RECEIVED)
  deliveredStatus         DeliveredTransferStatus @default(NOT_DELIVERED)
  status                  TransferStatus          @default(OPEN)
  isDeliveredAmountManual Boolean                 @default(false)
  notes                   String?
  cancelledAt             DateTime?
  cancellationReason      String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  commission              Commission?
  executions              TransferExecution[]

  @@index([date])
  @@index([customerId])
  @@index([type])
  @@index([receivedCurrency])
  @@index([deliveredCurrency])
  @@index([receivedStatus])
  @@index([deliveredStatus])
  @@index([status])
}

model TransferExecution {
  id            String                @id @default(cuid())
  transactionId String
  transaction   TransferTransaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  date          DateTime              @default(now())
  type          TransferExecutionType
  currency      Currency
  amount        Decimal               @db.Decimal(18, 4)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([transactionId])
  @@index([date])
  @@index([type])
  @@index([currency])
}

model Expense {
  id           String          @id @default(cuid())
  date         DateTime
  category     ExpenseCategory
  description  String
  amount       Decimal         @db.Decimal(18, 4)
  currencyCode Currency
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([date])
  @@index([category])
  @@index([currencyCode])
}

model CapitalMovement {
  id           String              @id @default(cuid())
  date         DateTime
  type         CapitalMovementType
  currencyCode Currency
  amount       Decimal             @db.Decimal(18, 4)
  description  String
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([date])
  @@index([type])
  @@index([currencyCode])
}

model Commission {
  id            String              @id @default(cuid())
  transactionId String              @unique
  transaction   TransferTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  personName    String?
  type          CommissionType
  base          CommissionBase
  value         Decimal             @db.Decimal(18, 8)
  amount        Decimal             @db.Decimal(18, 4)
  currencyCode  Currency
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([currencyCode])
  @@index([type])
  @@index([base])
}

model FinancialMovement {
  id                 String            @id @default(cuid())
  customerId         String?
  customer           Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  date               DateTime
  type               MovementType
  currency           Currency
  amount             Decimal           @db.Decimal(18, 4)
  rate               Decimal?          @db.Decimal(18, 6)
  notes              String?
  transactionGroupId String?
  transactionGroup   TransactionGroup? @relation(fields: [transactionGroupId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([date])
  @@index([customerId])
  @@index([transactionGroupId])
  @@index([type])
  @@index([currency])
}

model TransactionGroup {
  id                   String              @id @default(cuid())
  customerId           String
  customer             Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title                String?
  status               TransactionStatus   @default(OPEN)
  costRate             Decimal?            @db.Decimal(18, 6)
  sellRate             Decimal?            @db.Decimal(18, 6)
  sourceCurrency       Currency?
  targetCurrency       Currency?
  expectedSourceAmount Decimal?            @db.Decimal(18, 4)
  expectedTargetAmount Decimal?            @db.Decimal(18, 4)
  actualSourceAmount   Decimal?            @db.Decimal(18, 4)
  actualTargetAmount   Decimal?            @db.Decimal(18, 4)
  profit               Decimal?            @db.Decimal(18, 4)
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  financialMovements   FinancialMovement[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime
  usdToEgp  Decimal  @db.Decimal(18, 6)
  usdToTry  Decimal  @db.Decimal(18, 6)
  crossRate Decimal  @db.Decimal(18, 6)
  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
}
